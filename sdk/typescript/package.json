{
  "name": "@vynelix/vynrelay-sdk",
  "version": "1.0.1",
  "description": "Universal VynRelay client for Web and Node.js. Resilient messaging with automatic WebSocket to SSE fallback.",
  "keywords": ["vynrelay", "sdk", "websocket", "sse", "realtime", "messaging", "resilient", "fallback"],
  "author": "Vynelix",
  "type": "module",
  "main": "dist/client.js",
  "types": "dist/client.d.ts",
  "exports": {
    ".": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}