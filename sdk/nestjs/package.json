{
  "name": "@vynelix/vynrelay-nestjs",
  "version": "1.0.2",
  "description": "NestJS integration for VynRelay. Add real-time messaging decorators and shared-port support to any NestJS app.",
  "keywords": ["nestjs", "vynrelay", "realtime", "messaging", "websocket", "sse", "decorators"],
  "author": "Vynelix",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc"
  },
  "peerDependencies": {
    "@nestjs/common": "^8.0.0 || ^9.0.0 || ^10.0.0 || ^11.0.0",
    "@vynelix/vynrelay-server": "*",
    "@vynelix/vynrelay-sdk": "*"
  },
  "devDependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typescript": "^6.0.3"
  }
}
